<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Barbería</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: #f5f5f5; color: #1a1a1a; padding: 20px; }
    .dash { max-width: 680px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem; }
    .header h1 { font-size: 20px; font-weight: 500; }
    .header p { font-size: 13px; color: #666; margin-top: 3px; }
    .refresh-btn { font-size: 13px; color: #666; background: white; border: 0.5px solid #ddd; border-radius: 8px; padding: 6px 12px; cursor: pointer; display: flex; align-items: center; gap: 6px; text-decoration: none; }
    .refresh-btn:hover { background: #f5f5f5; }
    .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 1.5rem; }
    .stat { background: #efefef; border-radius: 8px; padding: 14px 16px; }
    .stat-num { font-size: 28px; font-weight: 500; color: #1a1a1a; }
    .stat-num.success { color: #0F6E56; }
    .stat-num.pending { color: #854F0B; }
    .stat-label { font-size: 12px; color: #666; margin-top: 2px; }
    .section { margin-bottom: 1.5rem; }
    .section-header { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 0.5px solid #ddd; }
    .section-header i { font-size: 16px; color: #888; }
    .section-title { font-size: 14px; font-weight: 500; }
    .section-count { font-size: 12px; color: #666; background: #efefef; border: 0.5px solid #ddd; border-radius: 20px; padding: 2px 8px; }
    .cita { background: white; border: 0.5px solid #e0e0e0; border-radius: 12px; padding: 14px 16px; margin-bottom: 8px; display: flex; align-items: center; gap: 16px; }
    .cita-hora { font-size: 18px; font-weight: 500; min-width: 72px; }
    .cita-divider { width: 0.5px; height: 36px; background: #e0e0e0; }
    .cita-info { flex: 1; }
    .cita-servicio { font-size: 14px; font-weight: 500; }
    .cita-tel { font-size: 12px; color: #888; margin-top: 2px; display: flex; align-items: center; gap: 4px; }
    .badge { font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 20px; }
    .badge-confirmada { background: #E1F5EE; color: #085041; }
    .badge-completada { background: #E6F1FB; color: #0C447C; }
    .badge-cancelada { background: #FCEBEB; color: #791F1F; }
    .btn-listo { font-size: 12px; background: white; border: 0.5px solid #ccc; border-radius: 8px; padding: 6px 12px; cursor: pointer; color: #1a1a1a; display: flex; align-items: center; gap: 4px; white-space: nowrap; }
    .btn-listo:hover { background: #f5f5f5; }
    .empty { text-align: center; padding: 32px; color: #999; font-size: 14px; background: #efefef; border-radius: 12px; }
  </style>
</head>
<body>
  <div class="dash">
    <div class="header">
      <div>
        <h1>Panel barbería</h1>
        <p><%= fecha %></p>
      </div>
      <a href="/admin" class="refresh-btn">
        <i class="ti ti-refresh"></i> Actualizar
      </a>
    </div>

    <div class="stats">
      <div class="stat">
        <div class="stat-num"><%= totalHoy %></div>
        <div class="stat-label">Citas hoy</div>
      </div>
      <div class="stat">
        <div class="stat-num success"><%= completadas %></div>
        <div class="stat-label">Completadas</div>
      </div>
      <div class="stat">
        <div class="stat-num pending"><%= pendientes %></div>
        <div class="stat-label">Pendientes</div>
      </div>
    </div>

    <% if (citas.length === 0) { %>
      <div class="empty">No hay citas para hoy</div>
    <% } %>

    <% barberos.forEach(barbero => { %>
      <% const citasBarbero = citas.filter(c => c.barbero === barbero) %>
      <% if (citasBarbero.length > 0) { %>
      <div class="section">
        <div class="section-header">
          <i class="ti ti-user"></i>
          <span class="section-title"><%= barbero %></span>
          <span class="section-count"><%= citasBarbero.length %> citas</span>
        </div>
        <% citasBarbero.forEach(cita => { %>
        <div class="cita" id="cita-<%= cita.id %>">
          <span class="cita-hora"><%= cita.hora %></span>
          <div class="cita-divider"></div>
          <div class="cita-info">
            <div class="cita-servicio"><%= cita.servicio %></div>
            <div class="cita-tel">
              <i class="ti ti-phone" style="font-size:12px"></i>
              +<%= cita.telefono %>
            </div>
          </div>
          <span class="badge badge-<%= cita.estado %>"><%= cita.estado %></span>
          <% if (cita.estado === 'confirmada') { %>
          <button class="btn-listo" onclick="completar(<%= cita.id %>)">
            <i class="ti ti-check" style="font-size:14px"></i> Listo
          </button>
          <% } %>
        </div>
        <% }) %>
      </div>
      <% } %>
    <% }) %>
  </div>

  <script>
    async function completar(id) {
      await fetch('/admin/completar/' + id, { method: 'POST' });
      location.reload();
    }
    setTimeout(() => location.reload(), 60000);
  </script>
</body>
</html>
